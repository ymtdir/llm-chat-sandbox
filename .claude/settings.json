{
  "permissions": {
    "allow": [
      "Bash(gh:*)",
      "Skill(issue-creation)",
      "Skill(issue-resolution)",
      "Skill(pr-creation)",
      "Skill(pr-review)"
    ]
  },
  "sandbox": {
    "network": {
      "allowedDomains": ["github.com"]
    }
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/claude-plugins-official.git"
      }
    }
  },
  "skills": {
    "allowed": [
      "issue-creation",
      "issue-resolution",
      "pr-creation",
      "pr-review"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath' | { read -r f; [ -f \"$f\" ] && ./node_modules/.bin/prettier --write --ignore-unknown \"$f\"; } 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
