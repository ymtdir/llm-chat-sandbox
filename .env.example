# ======================
# データベース設定
# ======================
# データベース認証情報（Docker Compose用）
DB_USER=postgres
DB_PASSWORD=postgres  # 本番環境では必ず変更してください
DB_NAME=ai_diary_companion

# PostgreSQL接続URL（主にAlembicマイグレーション用）
# 形式: postgresql+psycopg://user:password@host:port/database
# ローカル開発: localhost:5432
# Docker Compose内: postgres:5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ai_diary_companion

# 非同期用PostgreSQL接続URL（アプリケーション実行時に使用）
# 形式: postgresql+psycopg://user:password@host:port/database
# SQLAlchemy 2.0のasync engineで使用されます
# ローカル開発: localhost:5432
# Docker Compose内: postgres:5432（docker-compose.ymlで上書き）
ASYNC_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ai_diary_companion

# ======================
# セキュリティ設定
# ======================
# JWT Secret Key (本番環境では必ず変更すること)
# 生成方法: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production

# JWTトークンの有効期限（分）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# パスワードハッシュ化のソルトラウンド数
BCRYPT_ROUNDS=12

# ======================
# LLM API設定 (Groq)
# ======================
# Groq API Key
# 取得先: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# 使用するLLMモデル
GROQ_MODEL=llama-3.3-70b-versatile

# LLM応答生成のタイムアウト（秒）
LLM_TIMEOUT=30

# LLM応答生成の最大リトライ回数
LLM_MAX_RETRIES=3

# ======================
# Firebase設定 (プッシュ通知)
# ======================
# Firebase Admin SDK認証情報JSONファイルのパス
# 取得先: Firebase Console > プロジェクト設定 > サービスアカウント
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ======================
# アプリケーション設定
# ======================
# 環境 (development, staging, production)
ENVIRONMENT=development

# デバッグモード (開発環境ではtrue推奨)
DEBUG=true

# アプリケーション名
APP_NAME=AI Diary Companion

# APIのベースURL
API_BASE_URL=http://localhost:8000

# フロントエンドのベースURL
FRONTEND_URL=http://localhost:3000

# CORS許可オリジン（カンマ区切りで複数指定可能）
CORS_ORIGINS=http://localhost:3000

# ======================
# スケジューラー設定
# ======================
# 予約返信のポーリング間隔（秒）
SCHEDULER_CHECK_INTERVAL_SECONDS=60

# 日記生成の実行時刻 (cron形式: 時 分)
# デフォルト: 毎日深夜0時5分
DIARY_GENERATION_HOUR=0
DIARY_GENERATION_MINUTE=5

# ======================
# ログ設定
# ======================
# ログレベル (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ログフォーマット (json, text)
LOG_FORMAT=text

# ======================
# テスト設定 (pytest用)
# ======================
# テスト用データベースURL
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ai_diary_companion_test
